{
  "openapi": "3.0.0",
  "paths": {
    "/api/health": {
      "get": {
        "operationId": "getHealth",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Application health status with database connection info",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" }
              }
            }
          }
        },
        "summary": "Check application health and database status",
        "tags": ["health"]
      }
    },
    "/api/profile/{personId}": {
      "get": {
        "operationId": "ProfileController_getProfile",
        "parameters": [
          {
            "name": "personId",
            "required": true,
            "in": "path",
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "" } },
        "summary": "Get full user profile",
        "tags": ["profile"]
      }
    },
    "/api/profile/email/{email}": {
      "get": {
        "operationId": "ProfileController_getProfileByEmail",
        "parameters": [
          {
            "name": "email",
            "required": true,
            "in": "path",
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "" } },
        "summary": "Get full user profile by email",
        "tags": ["profile"]
      }
    },
    "/api/profile/{personId}/personal": {
      "patch": {
        "operationId": "ProfileController_updatePerson",
        "parameters": [
          {
            "name": "personId",
            "required": true,
