    }
  },
  "info": {
    "title": "TrustMed Core API",
    "description": "API documentation for the TrustMed Core backend",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [{ "name": "health", "description": "Health check endpoints" }],
  "servers": [],
  "components": {
    "schemas": {
      "DatabaseHealth": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["connected", "disconnected"],
            "example": "connected"
          },
          "type": {
            "type": "string",
            "example": "postgres",
            "description": "The type of database currently in use"
          }
        },
        "required": ["status", "type"]
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["up", "down"],
            "example": "up"
          },
          "uptime": {
            "type": "number",
            "example": 3600,
            "description": "Application uptime in seconds"
          },
          "timestamp": {
            "type": "string",
            "example": "2026-03-07T12:00:00.000Z",
            "description": "ISO timestamp of the health check"
          },
          "message": {
            "type": "string",
            "example": "Backend is running and database is connected"
          },
          "database": { "$ref": "#/components/schemas/DatabaseHealth" }
        },
        "required": ["status", "uptime", "timestamp", "message"]
      }
    }
  }
}
