  "info": {
    "title": "TrustMed Core API",
    "description": "API documentation for the TrustMed Core backend",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "health",
      "description": "Health check endpoints"
    }
  ],
  "servers": [],
  "components": {
    "schemas": {
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "example": "password123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "AuthMessageDto": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Login successful"
          }
        },
        "required": [
          "message"
        ]
      },
      "ErrorResponseDto": {
        "type": "object",
        "properties": {
          "statusCode": {
            "type": "number",
            "example": 401
          },
          "message": {
            "type": "string",
            "example": "Invalid email or password"
          },
          "error": {
            "type": "string",
            "example": "Unauthorized"
          }
        },
        "required": [
          "statusCode",
          "message",
          "error"
        ]
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "example": "password123"
          },
          "firstName": {
            "type": "string",
            "example": "John"
          },
          "lastName": {
            "type": "string",
            "example": "Doe"
          }
        },
        "required": [
          "email",
          "password",
          "firstName"
        ]
      },
      "User": {
        "type": "object",
        "properties": {
          "sub": {
            "type": "string",
            "example": "user_123"
          },
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "firstName": {
            "type": "string",
            "example": "John"
          },
          "lastName": {
            "type": "string",
            "example": "Doe"
          }
        },
        "required": [
          "sub",
          "email"
        ]
      },
      "DatabaseHealth": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "connected",
              "disconnected"
            ],
            "example": "connected"
          },
          "type": {
            "type": "string",
            "example": "postgres",
            "description": "The type of database currently in use"
          }
        },
        "required": [
          "status",
          "type"
        ]
      },
      "HealthResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "up",
              "down"
            ],
            "example": "up"
          },
          "uptime": {
            "type": "number",
            "example": 3600,
            "description": "Application uptime in seconds"
          },
          "timestamp": {
            "type": "string",
            "example": "2026-03-07T12:00:00.000Z",
            "description": "ISO timestamp of the health check"
          },
          "message": {
            "type": "string",
            "example": "Backend is running and database is connected"
          },
          "database": {
            "$ref": "#/components/schemas/DatabaseHealth"
          }
        },
        "required": [
          "status",
          "uptime",
          "timestamp",
          "message"
        ]
      },
      "SubStatusDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "UP",
              "DOWN",
              "DEGRADED"
            ],
            "example": "UP"
          },
          "mspId": {
            "type": "string",
            "example": "Org1MSP"
          },
          "timestamp": {
            "type": "string",
            "example": "2026-03-22T05:30:41.076Z"
          },
          "details": {
            "type": "string",
            "example": "PEER_UNREACHABLE"
          }
        },
        "required": [
          "status"
        ]
      },
      "NetworkStatusDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "UP",
              "DOWN",
              "DEGRADED"
            ],
            "example": "UP"
          },
          "mspId": {
            "type": "string",
            "example": "Org1MSP"
          },
          "timestamp": {
            "type": "string",
            "example": "2026-03-22T05:30:41.076Z"
          },
          "details": {
            "type": "string",
            "example": "PEER_UNREACHABLE"
          },
          "channel": {
            "type": "string",
            "example": "mychannel"
          },
          "chaincode": {
            "type": "string",
            "example": "trustmed"
          }
        },
        "required": [
          "status",
          "channel",
          "chaincode"
        ]
      },
      "BlockchainHealthResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "OK",
              "ERROR",
              "DEGRADED"
            ],
            "example": "OK"
          },
          "gateway": {
            "$ref": "#/components/schemas/SubStatusDto"
          },
          "network": {
            "$ref": "#/components/schemas/NetworkStatusDto"
          }
        },
        "required": [
          "status",
          "gateway",
          "network"
        ]
      }
    }
  }
}