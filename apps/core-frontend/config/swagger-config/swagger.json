    "/api/profile/{personId}/allergies": {
      "post": {
        "operationId": "ProfileController_addAllergy",
        "parameters": [
          {
            "name": "personId",
            "required": true,
            "in": "path",
            "schema": { "type": "string" }
          }
        ],
        "responses": { "201": { "description": "" } },
        "summary": "Add allergy",
        "tags": ["profile"]
      }
    },
    "/api/profile/allergies/{id}": {
      "delete": {
        "operationId": "ProfileController_deleteAllergy",
        "parameters": [
          {
            "name": "id",
            "required": true,
