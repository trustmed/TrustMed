        "summary": "Update medical profile",
        "tags": ["profile"]
      }
    },
    "/api/profile/{personId}/allergies": {
      "post": {
        "operationId": "ProfileController_addAllergy",
        "parameters": [
          {
            "name": "personId",
            "required": true,
            "in": "path",
            "schema": { "type": "string" }
          }
        ],
        "responses": { "201": { "description": "" } },
        "summary": "Add allergy",
        "tags": ["profile"]
      }
    },
    "/api/profile/allergies/{id}": {
      "delete": {
        "operationId": "ProfileController_deleteAllergy",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "" } },
        "summary": "Delete allergy",
        "tags": ["profile"]
      }
    },
    "/api/profile/{personId}/medications": {
      "post": {
        "operationId": "ProfileController_addMedication",
        "parameters": [
          {
            "name": "personId",
            "required": true,
            "in": "path",
            "schema": { "type": "string" }
          }
        ],
        "responses": { "201": { "description": "" } },
        "summary": "Add medication",
        "tags": ["profile"]
      }
    },
    "/api/profile/medications/{id}": {
      "delete": {
        "operationId": "ProfileController_deleteMedication",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "" } },
        "summary": "Delete medication",
        "tags": ["profile"]
      }
    },
    "/api/profile/{personId}/contacts": {
      "post": {
        "operationId": "ProfileController_addEmergencyContact",
        "parameters": [
          {
            "name": "personId",
            "required": true,
            "in": "path",
            "schema": { "type": "string" }
          }
        ],
        "responses": { "201": { "description": "" } },
        "summary": "Add emergency contact",
        "tags": ["profile"]
      }
    },
    "/api/profile/contacts/{id}": {
      "delete": {
        "operationId": "ProfileController_deleteEmergencyContact",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "" } },
        "summary": "Delete emergency contact",
        "tags": ["profile"]
